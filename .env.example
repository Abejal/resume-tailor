# Copy to .env and fill in real values. Never commit .env.

# Supabase (frontend)
VITE_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key"
VITE_SUPABASE_PROJECT_ID="your-project-id"

# App
VITE_APP_URL="http://localhost:8080"

# ---- Edge function secrets (set via `npx supabase secrets set ...`) ----
# GOOGLE_AI_API_KEY=                          # Google AI Studio key for Gemini 2.5 Flash
# GROQ_API_KEY=                               # Groq key for Llama 3.3 70B fallback
#
# TOYYIBPAY_BASE_URL=https://dev.toyyibpay.com   # sandbox; use https://toyyibpay.com for live
# TOYYIBPAY_SECRET_KEY=                          # from toyyibpay dashboard → Profile → API
# TOYYIBPAY_CATEGORY_CODE=                       # create one category in toyyibpay, paste its code
# TOYYIBPAY_PRICE_MONTHLY=2900                   # RM29.00 in cents
# TOYYIBPAY_PRICE_ANNUAL=29000                   # RM290.00 in cents
# TOYYIBPAY_PRICE_TOPUP=1000                     # RM10.00 in cents
#
# ALLOWED_ORIGIN=https://your-prod-domain.com
